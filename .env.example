# Copy this file to .env and fill in your keys.
# Never commit your actual .env file — it is listed in .gitignore.

# Required for the web search tool (https://tavily.com — free tier available)
TAVILY_API_KEY=your-tavily-api-key-here

# Required for document QA embeddings (https://platform.openai.com/api-keys)
# Uses text-embedding-3-small (~$0.02 / 1M tokens)
OPENAI_API_KEY=your-openai-api-key-here

# Optional — Redis session store
# When set, conversation history is persisted to Redis instead of in-memory.
# For local dev with docker-compose this is set automatically.
# For Azure: rediss://:password@your-instance.redis.cache.windows.net:6380
REDIS_URL=

# Optional — Tracing backend (noop | langfuse)
TRACING_BACKEND=noop

# Required only when TRACING_BACKEND=langfuse
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=
